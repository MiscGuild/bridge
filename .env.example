# =====================================================
# Guild Bridge Bot — Environment Configuration
# Copy this file to .env and fill in all required values
# =====================================================

# ==================== MINECRAFT ====================
MINECRAFT_EMAIL=your-minecraft-email@example.com
# MINECRAFT_PASSWORD=                  # Only needed for non-Microsoft auth which is deprecated and may not work reliably
MINECRAFT_CHAT_SEPARATOR=»
MINECRAFT_RECONNECT_DELAY=10           # Seconds to wait before reconnecting

# ==================== HYPIXEL ====================
HYPIXEL_API_KEY=your-hypixel-api-key
# FALLBACK_HYPIXEL_API_KEY=            # Optional fallback key
# 2ND_FALLBACK_HYPIXEL_API_KEY=        # Optional second fallback key
HYPIXEL_GUILD_NAME=YourGuildName

# ==================== DISCORD ====================
DISCORD_TOKEN=your-discord-bot-token
DISCORD_SERVER_ID=123456789012345678
DISCORD_IGNORE_PREFIX=!
DISCORD_INVITE_LINK=discord.gg/yourinvite
MEMBER_CHANNEL_ID=123456789012345678
OFFICER_CHANNEL_ID=123456789012345678
BLACKLIST_CHANNEL_ID=123456789012345678
BOT_OWNER_ID=123456789012345678
STAFF_ROLE_ID=123456789012345678

# ==================== DISCORD OAUTH (optional — for dashboard) ====================
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=http://localhost:3001/api/v1/auth/discord/callback

# ==================== SUPABASE (optional — enables DB persistence) ====================
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-role-key

# ==================== EXPRESS API ====================
API_PORT=3001
# API_KEY=your-secret-api-key         # Optional; enables API key auth

JWT_SECRET=change-this-to-a-random-secret

# ==================== FILTERS ====================
USE_PROFANITY_FILTER=true
USE_BRAINROT_FILTER=true # Not reccomended to enable this filter as it can cause false positives and may block non-toxic messages. Use with caution.
USE_FIRST_WORD_OF_AUTHOR_NAME=false
# Use the Minimum Network Level auto kick newly joined members under this threshold. Set to 0 to disable. Not reccomended for larger or public guilds. 
MINIMUM_NETWORK_LEVEL=0

# ==================== REMINDERS ====================
REMINDER_ENABLED=false
REMINDER_MESSAGE= # Example: "Don't forget to check the guild chat for important updates!"
REMINDER_FREQUENCY=60                  # Minutes between reminders

# ==================== STAFF / MODERATION ====================
# BAN_ALLOWED_RANKS=Officer,Staff      # Comma-separated ranks that can ban
BAN_CHECK_INTERVAL=10                  # Minutes between ban enforcement checks
URCHIN_JOIN_CHECK=false                # Auto-check new members against Urchin blacklist

# ==================== TERMINAL REPL ====================
ENABLE_TERMINAL=false
ENABLE_TERMINAL_COMMANDS=true
ENABLE_TERMINAL_LOGS=true
ENABLE_TERMINAL_LOG_COLORS=true
ENABLE_TERMINAL_CHAT=false

# ==================== COOLDOWNS (seconds per rank) ====================
COOLDOWN_RANK_1=60
COOLDOWN_RANK_2=20
COOLDOWN_RANK_3=15
COOLDOWN_RANK_4=12
COOLDOWN_RANK_5=10
COOLDOWN_GUILD_MASTER=0
COOLDOWN_URCHIN=5

# ==================== RANK NAMES ====================
RANK_1=
RANK_2=
RANK_3=
RANK_4=
RANK_5=
RANK_LEADER=Guild Master #Hardcoded since Hypixel doesn't allow the Guild Master rank to renamed. Notable is that the Guild Master rank tag can be disabeled in Hypixel's guild settings. If disabeled, the bot will default to using "Leader" as the rank name for cooldown and permission purposes.
